
# Brsk's network or router seems to have trouble with ipv6, so force ipv4
AddressFamily inet

# ControlMaster auto
# ControlPath   /home/david/.ssh/tmp/%h_%p_%r

# Always add keys to ssh-agent
AddKeysToAgent yes

Host github.com
    # Not sure why I need to specify this for github when others can use the
    # top-level setting...
    AddKeysToAgent yes

Host github-personal
    HostName github.com
    User git
    IdentityFile "~/.ssh/davidshepherd7"
    IdentitiesOnly yes
    AddKeysToAgent yes
 
Include local_config
